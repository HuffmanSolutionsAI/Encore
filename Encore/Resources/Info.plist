	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>EncoreAPIBaseURL</key>
	<string>$(ENCORE_API_BASE_URL)</string>
	<key>EncoreCognitoDomain</key>
	<string>$(ENCORE_COGNITO_DOMAIN)</string>
