# Public web-app configuration. Copy to .env.local and fill from `terraform output`
# in infra/. These values are baked into the client bundle — only put values
# here that are safe to ship to a browser.

NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
