# Public web-app configuration. Copy to .env.local and pick a mode below.

# === Local dev (recommended first pass — no AWS account needed) ====
# Point at the local API server (`cd api && npm run dev`) and switch on
# dev mode. The signin page shows "Sign in as dev"; auth is a UUID in
# localStorage instead of Cognito.

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_DEV_MODE=true

# === Real Cognito (AWS deploy) ====================================
# Comment the two lines above and uncomment + fill these from
# `terraform output`. NEXT_PUBLIC_DEV_MODE must be unset (or "false").

# NEXT_PUBLIC_API_BASE_URL=https://abc123.execute-api.us-east-1.amazonaws.com
# NEXT_PUBLIC_COGNITO_DOMAIN=encore-dev-1234.auth.us-east-1.amazoncognito.com
# NEXT_PUBLIC_COGNITO_CLIENT_ID=
# NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
