# Encore — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# --- iOS client configuration (safe to ship in the app) ---
# Populate from `terraform output` after deploying infra/. In Xcode, set these as
# user-defined build settings (ENCORE_API_BASE_URL etc.) — Info.plist substitutes
# them at build time. AppConfig reads the resolved values at runtime.
API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1
COGNITO_DOMAIN=encore-000000000000.auth.us-east-1.amazoncognito.com
COGNITO_REDIRECT_URI=encore://auth-callback

# --- Backend secrets ---
# Not set here. Database credentials and third-party API keys live in AWS
# Secrets Manager and are read at runtime by the API Lambda:
#   encore-<env>/database     RDS connection details (generated by Terraform)
#   encore-<env>/thirdparty   LASTFM_API_KEY, LASTFM_SHARED_SECRET, MUSICBRAINZ_USER_AGENT
# Sign in with Apple credentials go in infra/terraform.tfvars (gitignored).
