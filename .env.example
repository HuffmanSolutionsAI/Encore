# Encore — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# All third-party keys are server-side only (Supabase Edge Functions). Never ship a key in the app.

# --- Supabase project (public, safe for the iOS client) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- Edge Function secrets (server-side only — set via `supabase secrets set`) ---
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_SHARED_SECRET=your-lastfm-shared-secret
MUSICBRAINZ_USER_AGENT=Encore/1.0 ( contact@example.com )
