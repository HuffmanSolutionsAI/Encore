{
  "name": "encore-api",
  "version": "1.0.0",
  "private": true,
  "description": "Encore backend API — AWS Lambda behind API Gateway.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node20 --external:@aws-sdk/* --outfile=dist/handler.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "dotenv -e .env -- tsx watch src/local.ts",
    "migrate": "dotenv -e .env -- tsx src/migrate.ts"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.11.10",
    "dotenv-cli": "^7.4.4",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
