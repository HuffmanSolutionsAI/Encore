# Local dev for the Encore API. Copy to .env (gitignored).

# Connection string for the local Postgres container (docker-compose.yml).
DATABASE_URL=postgres://encore:encore@localhost:5432/encore

# Skip Cognito JWT validation; trust the `x-dev-user-id` header instead.
# NEVER set this in production — the Lambda never sets it; the AWS deploy
# falls back to the real authorizer.
DEV_AUTH=1

# Web dev origin allowed by the local server's CORS.
WEB_ORIGIN=http://localhost:3000

# Optional: Last.fm key. Without it, /now-playing returns a 503 and the
# rest of the app still works.
# Get one at https://www.last.fm/api/account/create
LASTFM_API_KEY=
